                  "});\r",
                  "\r",
                  "pm.test(\"Pagination values are correct\", function () {\r",
                  "    let jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.current_page).to.eql(2);\r",
                  "    pm.expect(jsonData.per_page).to.eql(1);\r",
                  "    pm.expect(jsonData.from).to.eql(2);\r",
                  "    pm.expect(jsonData.to).to.eql(2);\r",
                  "});\r",
